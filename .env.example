# OPN Chain testnet deployment config.
# Copy this file to .env and fill in DEPLOYER_PRIVATE_KEY. NEVER commit .env.

# RPC endpoint of the OPN Chain testnet.
OPN_TESTNET_RPC=https://testnet-rpc.iopn.tech

# Chain ID of the OPN Chain testnet.
OPN_TESTNET_CHAIN_ID=984

# Block explorer (used for verifying deployed contracts / viewing txs).
OPN_TESTNET_EXPLORER=https://testnet.iopn.tech

# Private key of the deployer account (must hold testnet gas tokens).
# 0x-prefixed hex. Use a throwaway key, not a key with real funds.
DEPLOYER_PRIVATE_KEY=
